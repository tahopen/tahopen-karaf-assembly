        <configfile finalname="/etc/pentaho.geo.roles.cfg">mvn:pentaho/pentaho-osgi-config/0.1.0.0/cfg/pentaho-geo-roles</configfile>
        <feature>pentaho-dataservice</feature>
        <bundle dependency="true">wrap:mvn:pentaho/pentaho-modeler/0.1.0.0</bundle>
        <bundle dependency="true">wrap:mvn:jfree/jcommon/1.0.14</bundle>
